generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String?
  role         String    @default("ADMIN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  callLogs     CallLog[]

  @@map("admin_users")
}

model MobileUser {
  id           String   @id @default(uuid())
  name         String?
  username     String   @unique
  mobileNumber String?
  password     String
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  callLogs     CallLog[]
  leads        Lead[]

  @@map("mobile_users")
}

model Lead {
  id             String       @id @default(uuid())
  phoneNumber    String       @unique
  name           String?
  status         LeadStatus   @default(NEW)
  assignedToId   String?
  lastCallAt     DateTime?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  email          String?
  nextFollowUpAt DateTime?
  priority       LeadPriority @default(MEDIUM)
  source         String?
  serialId       Int?         @unique(map: "serialId") @default(autoincrement())
  callLogs       CallLog[]
  assignedTo     MobileUser?   @relation(fields: [assignedToId], references: [id])

  @@index([assignedToId], map: "leads_assignedToId_fkey")
  @@map("leads")
}

model CallLog {
  id           String   @id @default(uuid())
  phoneNumber  String
  duration     Int?     @default(0)
  leadId       String?
  createdAt    DateTime @default(now())
  callType     String   @default("INCOMING")
  callerId     String?
  adminId      String?
  notes        String?  @db.Text
  outcome      String?
  recordingUrl String?
  serialId     Int      @unique(map: "serialId") @default(autoincrement())
  caller       MobileUser? @relation(fields: [callerId], references: [id])
  admin        AdminUser?  @relation(fields: [adminId], references: [id])
  lead         Lead?    @relation(fields: [leadId], references: [id])
  mobileId     String?
  mobileName   String?

  @@index([callerId], map: "call_logs_callerId_fkey")
  @@index([adminId], map: "call_logs_adminId_fkey")
  @@index([leadId], map: "call_logs_leadId_fkey")
  @@map("call_logs")
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  COMPLETED
  NOT_INTERESTED
  NO_ANSWER
  CLOSED
  INVALID_WRONG
  CALL_SUCCESS
  RECALL
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}
