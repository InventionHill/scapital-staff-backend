generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String?
  role         String    @default("ADMIN") // Fixed to ADMIN
  branchId     String?   @unique // Ensure only one admin per branch
  branch       Branch?   @relation(fields: [branchId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  callLogs     CallLog[]
  mobileIds    Json?     // Array of strings: ["id1", "id2"]

  @@map("admin_users")
}

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("SUPER_ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

model MobileUser {
  id           String   @id @default(uuid())
  name         String?
  username     String   @unique
  mobileNumber String?
  password     String
  role         String   @default("USER")
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  callLogs     CallLog[]
  leads        Lead[]

  @@map("mobile_users")
}

model Lead {
  id             String       @id @default(uuid())
  phoneNumber    String       @unique
  name           String?
  status         LeadStatus   @default(NEW)
  assignedToId   String?
  lastCallAt     DateTime?
  statusRemark   String?      @db.Text
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  profile        String?      @db.VarChar(50)
  cibilStatus    String?      @db.VarChar(50)
  cibilRemark    String?      @db.Text
  email          String?
  nextFollowUpAt DateTime?
  priority       LeadPriority @default(MEDIUM)
  source         String?
  loanType       String?      @default("Other")
  customLoanType String?      @db.Text
  loanTypeId     String?
  branchId       String?
  mobileId       String?      // The incoming mobile ID that generated this lead
  branch         Branch?       @relation(fields: [branchId], references: [id])
  serialId       Int?         @unique(map: "serialId") @default(autoincrement())
  callLogs       CallLog[]
  assignedTo     MobileUser?   @relation(fields: [assignedToId], references: [id])
  assignedLoanType LoanType?     @relation(fields: [loanTypeId], references: [id], name: "AssignedLoanType")

  @@index([assignedToId], map: "leads_assignedToId_fkey")
  @@index([loanTypeId], map: "leads_loanTypeId_fkey")
  @@index([mobileId])
  applicationForm ApplicationForm?
  @@map("leads")
}

model ApplicationForm {
  id            String   @id @default(uuid())
  leadId        String   @unique
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Basic info
  name          String
  phoneNumber   String
  email         String?
  motherName    String?
  dob           String?
  companyName   String?
  fileNumber    String?

  // Nested structures as JSON
  addresses     Json?    // { current, permanent, office, property }
  financials    Json?    // { netSalaryInr, loanAmountInr, obligationInr }
  
  product       String?
  residentType  String?
  leadBy        String?

  references    Json?    // Array of { name, phoneNumber }
  coApplicants  Json?    // Array of { name, phoneNumber, email, motherName }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("application_forms")
}

model CallLog {
  id           String   @id @default(uuid())
  phoneNumber  String
  duration     Int?     @default(0)
  leadId       String?
  createdAt    DateTime @default(now())
  callType     String   @default("INCOMING")
  callerId     String?
  adminId      String?
  notes        String?  @db.Text
  outcome      String?
  recordingUrl String?
  serialId     Int      @unique(map: "serialId") @default(autoincrement())
  caller       MobileUser? @relation(fields: [callerId], references: [id])
  admin        AdminUser?  @relation(fields: [adminId], references: [id])
  lead         Lead?    @relation(fields: [leadId], references: [id])
  mobileId     String?
  mobileName   String?

  @@index([callerId], map: "call_logs_callerId_fkey")
  @@index([adminId], map: "call_logs_adminId_fkey")
  @@index([leadId], map: "call_logs_leadId_fkey")
  @@map("call_logs")
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  COMPLETED
  NOT_INTERESTED
  NO_ANSWER
  CLOSED
  INVALID_WRONG
  INTERESTED
  RECALL
  LOGIN
  SANCTIONED
  DISBURSEMENT
  REJECT
  DORMANT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum CibilStatus {
  ISSUED
  NOT_ISSUED
}

model LoanType {
  id        String         @id @default(uuid())
  name      String
  createdBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  documents LoanDocument[]
  leads     Lead[] @relation("AssignedLoanType")

  @@index([createdBy])
  @@map("loan_types")
}

model LoanDocument {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  loanTypeId  String
  loanType    LoanType @relation(fields: [loanTypeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("loan_documents")
}

model Branch {
  id          String   @id @default(uuid())
  name        String   @unique
  location    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admins      AdminUser[]
  mobileUsers MobileUser[]
  leads       Lead[]

  @@map("branches")
}
