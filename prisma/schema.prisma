generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("ADMIN")
  branchId  String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isEnabled Boolean   @default(true)
  mobileIds Json?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  callLogs  CallLog[]

  @@map("admin_users")
}

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("SUPER_ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

model MobileUser {
  id           String    @id @default(uuid())
  name         String?
  username     String    @unique
  mobileNumber String?
  password     String
  role         String    @default("USER")
  branchId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isEnabled    Boolean   @default(true)
  callLogs     CallLog[]
  leads        Lead[]
  branch       Branch?   @relation(fields: [branchId], references: [id])

  @@index([branchId], map: "mobile_users_branchId_fkey")
  @@map("mobile_users")
}

model Lead {
  id               String           @id @default(uuid())
  phoneNumber      String           @unique
  name             String?
  status           LeadStatus       @default(NEW)
  assignedToId     String?
  lastCallAt       DateTime?
  statusRemark     String?          @db.Text
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  profile          String?          @db.VarChar(50)
  cibilStatus      String?          @db.VarChar(50)
  cibilRemark      String?          @db.Text
  email            String?
  nextFollowUpAt   DateTime?
  priority         LeadPriority     @default(MEDIUM)
  source           String?
  loanType         String?          @default("Other")
  customLoanType   String?          @db.Text
  loanTypeId       String?
  branchId         String?
  mobileId         String?
  serialId         Int              @unique(map: "serialId") @default(autoincrement())
  branchSerialId   Int?
  applicationForm  ApplicationForm?
  callLogs         CallLog[]
  assignedTo       MobileUser?      @relation(fields: [assignedToId], references: [id])
  branch           Branch?          @relation(fields: [branchId], references: [id])
  assignedLoanType LoanType?        @relation("AssignedLoanType", fields: [loanTypeId], references: [id])

  @@index([assignedToId], map: "leads_assignedToId_fkey")
  @@index([loanTypeId], map: "leads_loanTypeId_fkey")
  @@index([mobileId])
  @@index([branchId], map: "leads_branchId_fkey")
  @@map("leads")
}

model ApplicationForm {
  id           String   @id @default(uuid())
  leadId       String   @unique
  name         String
  phoneNumber  String
  email        String?
  motherName   String?
  dob          String?
  companyName  String?
  fileNumber   String?
  addresses    Json?
  financials   Json?
  product      String?
  residentType String?
  leadBy       String?
  references   Json?
  coApplicants Json?
  pdfUrl       String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("application_forms")
}

model CallLog {
  id           String      @id @default(uuid())
  phoneNumber  String
  duration     Int?        @default(0)
  leadId       String?
  createdAt    DateTime    @default(now())
  callType     String      @default("INCOMING")
  callerId     String?
  adminId      String?
  notes        String?     @db.Text
  outcome      String?
  recordingUrl String?
  serialId     Int         @unique(map: "serialId") @default(autoincrement())
  mobileId     String?
  mobileName   String?
  admin        AdminUser?  @relation(fields: [adminId], references: [id])
  caller       MobileUser? @relation(fields: [callerId], references: [id])
  lead         Lead?       @relation(fields: [leadId], references: [id])

  @@index([callerId], map: "call_logs_callerId_fkey")
  @@index([adminId], map: "call_logs_adminId_fkey")
  @@index([leadId], map: "call_logs_leadId_fkey")
  @@map("call_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorType  String
  branchId   String?
  action     String
  details    String   @db.Text
  targetId   String?
  targetType String?
  createdAt  DateTime @default(now())
  branch     Branch?  @relation(fields: [branchId], references: [id])

  @@index([actorId])
  @@index([branchId])
  @@map("audit_logs")
}

model LoanType {
  id        String         @id @default(uuid())
  name      String
  createdBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  leads     Lead[]         @relation("AssignedLoanType")
  documents LoanDocument[]

  @@index([createdBy])
  @@map("loan_types")
}

model LoanDocument {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  loanTypeId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  loanType    LoanType @relation(fields: [loanTypeId], references: [id], onDelete: Cascade)

  @@index([loanTypeId], map: "loan_documents_loanTypeId_fkey")
  @@map("loan_documents")
}

model Branch {
  id               String       @id @default(uuid())
  name             String       @unique
  location         String?      @db.Text
  lastSerialNumber Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  admins           AdminUser?
  auditLogs        AuditLog[]
  leads            Lead[]
  mobileUsers      MobileUser[]

  @@map("branches")
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  COMPLETED
  NOT_INTERESTED
  NO_ANSWER
  CLOSED
  INVALID_WRONG
  INTERESTED
  RECALL
  LOGIN
  SANCTIONED
  DISBURSEMENT
  REJECT
  DORMANT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}
