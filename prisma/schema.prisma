generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String?
  role         String    @default("ADMIN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  callLogs     CallLog[]

  @@map("admin_users")
}

model MobileUser {
  id           String   @id @default(uuid())
  name         String?
  username     String   @unique
  mobileNumber String?
  password     String
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  callLogs     CallLog[]
  leads        Lead[]

  @@map("mobile_users")
}

model BankingPartner {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String
  redirectUrl String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loanProducts LoanProduct[]

  @@map("banking_partners")
}

model PlatformStat {
  id         String   @id @default(uuid())
  label      String
  value      String
  icon       String
  suffix     String   @default("+")
  status     String   @default("active")
  isAnimated Boolean  @default(true)
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("platform_stats")
}

model LoanBanner {
  id                       String        @id @default(uuid())
  title                    String
  imageUrl                 String
  redirectUrl              String?
  order                    Int           @default(0)
  isActive                 Boolean       @default(true)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  benefits                 Json?
  benefitsTitle            String?
  benefitsTitleHighlight   String?
  comparisonTable          Json?
  comparisonTitle          String?
  comparisonTitleHighlight String?
  ctaPrimary               Json?
  ctaSecondary             Json?
  defaultAmount            Float?        @default(500000)
  defaultInterest          Float?        @default(10.5)
  defaultTenure            Int?          @default(5)
  description              String?       @db.Text
  documents                Json?
  documentsTitle           String?
  features                 Json?
  heading                  String?
  headingHighlight         String?
  icon                     String?
  isDefault                Boolean       @default(false)
  maxAmount                Float?        @default(10000000)
  maxInterest              Float?        @default(25)
  maxTenure                Int?          @default(30)
  minAmount                Float?        @default(10000)
  minInterest              Float?        @default(5)
  minTenure                Int?          @default(1)
  overviewContent          String?       @db.Text
  overviewTitle            String?
  overviewTitleHighlight   String?
  pageContent              Json?
  ratesImage               String?
  ratesTable               Json?
  ratesTitle               String?
  ratesTitleHighlight      String?
  steps                    Json?
  stepsButtonLabel         String?
  stepsTitle               String?
  stepsTitleHighlight      String?
  loanProducts             LoanProduct[]

  @@map("loan_banners")
}

model LoanProduct {
  id               String            @id @default(uuid())
  name             String
  icon             String?
  applyLabel       String?
  applyUrl         String?
  interestRate     String?
  processingFee    String?
  order            Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  loanBannerId     String?
  bankingPartnerId String?
  values           ComparisonValue[]
  loanBanner       LoanBanner?       @relation(fields: [loanBannerId], references: [id])
  bankingPartner   BankingPartner?   @relation(fields: [bankingPartnerId], references: [id])

  @@index([loanBannerId])
  @@index([bankingPartnerId])
  @@map("loan_products")
}

model ComparisonParameter {
  id        String            @id @default(uuid())
  title     String
  order     Int               @default(0)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  values    ComparisonValue[]

  @@map("comparison_parameters")
}

model ComparisonValue {
  id          String              @id @default(uuid())
  value       String
  productId   String
  parameterId String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  parameter   ComparisonParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)
  product     LoanProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, parameterId])
  @@index([parameterId], map: "comparison_values_parameterId_fkey")
  @@map("comparison_values")
}

model ClientTestimonial {
  id          String   @id @default(uuid())
  name        String
  designation String?
  content     String   @db.Text
  rating      Int      @default(5)
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("client_testimonials")
}

model FAQ {
  id          String   @id @default(uuid())
  question    String
  answer      String   @db.Text
  category    String?  @default("General")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  defaultOpen Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("faqs")
}

model SectionContent {
  id              String   @id @default(uuid())
  sectionKey      String   @unique
  heading         String?
  highlightedText String?
  description     String?  @db.Text
  isActive        Boolean  @default(true)
  extraConfig     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("section_contents")
}

model LoanApplication {
  id         String   @id @default(uuid())
  fullName   String
  email      String?
  phoneNumber String?
  loanType   String?
  loanAmount String?
  tenure     String?
  documents  Json?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("loan_applications")
}

model KeyDepartment {
  id         String   @id @default(uuid())
  title      String
  experience String
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("key_departments")
}

model EmployeeTestimonial {
  id        String   @id @default(uuid())
  name      String
  position  String
  content   String   @db.Text
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_testimonials")
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String   @default("General")
  content     String   @db.Text
  imageUrl    String?
  author      String?
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogs")
}

model ContactInfo {
  id           String   @id @default(uuid())
  phone        String
  email        String
  workingHours String
  address      String
  mapUrl       String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("contact_infos")
}

model SocialLink {
  id        String   @id @default(uuid())
  platform  String   @unique
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("social_links")
}

model JobApplication {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  phoneNumber String
  position  String?
  resumeUrl String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("job_applications")
}

model Lead {
  id             String       @id @default(uuid())
  phoneNumber    String       @unique
  name           String?
  status         LeadStatus   @default(NEW)
  assignedToId   String?
  lastCallAt     DateTime?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  email          String?
  nextFollowUpAt DateTime?
  priority       LeadPriority @default(MEDIUM)
  source         String?
  serialId       Int?         @unique(map: "serialId") @default(autoincrement())
  callLogs       CallLog[]
  assignedTo     MobileUser?   @relation(fields: [assignedToId], references: [id])

  @@index([assignedToId], map: "leads_assignedToId_fkey")
  @@map("leads")
}

model CallLog {
  id           String   @id @default(uuid())
  phoneNumber  String
  duration     Int?     @default(0)
  leadId       String?
  createdAt    DateTime @default(now())
  callType     String   @default("INCOMING")
  callerId     String?
  adminId      String?
  notes        String?  @db.Text
  outcome      String?
  recordingUrl String?
  serialId     Int      @unique(map: "serialId") @default(autoincrement())
  caller       MobileUser? @relation(fields: [callerId], references: [id])
  admin        AdminUser?  @relation(fields: [adminId], references: [id])
  lead         Lead?    @relation(fields: [leadId], references: [id])
  mobileId     String?
  mobileName   String?

  @@index([callerId], map: "call_logs_callerId_fkey")
  @@index([adminId], map: "call_logs_adminId_fkey")
  @@index([leadId], map: "call_logs_leadId_fkey")
  @@map("call_logs")
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  COMPLETED
  NOT_INTERESTED
  NO_ANSWER
  CLOSED
  INVALID_WRONG
  CALL_SUCCESS
  RECALL
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}
